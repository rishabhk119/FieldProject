# ── Collaborator client env ──────────────────────────────
# Copy this file to .env.local and set the server IP below.
# This file is gitignored — each collaborator sets their own.
#
# Ask the main developer for their machine's local IP address.
# They can find it with: ipconfig (Windows) or ifconfig (Mac/Linux)
#
# Example: VITE_API_URL=http://192.168.1.105:5000
VITE_API_URL=http://localhost:5000
